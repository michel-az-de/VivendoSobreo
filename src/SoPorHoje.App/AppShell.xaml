<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="SoPorHoje.App.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:SoPorHoje.App.Views"
    Title="Só Por Hoje"
    Shell.BackgroundColor="#0C1219"
    Shell.ForegroundColor="#E2E8F0"
    Shell.TitleColor="#E2E8F0"
    Shell.TabBarBackgroundColor="#0C1219"
    Shell.TabBarForegroundColor="#3A8AC5"
    Shell.TabBarTitleColor="#3A8AC5"
    Shell.TabBarUnselectedColor="#49596B"
    Shell.NavBarHasShadow="False">

    <TabBar>
        <ShellContent
            Title="Hoje"
            Icon="tab_home"
            ContentTemplate="{DataTemplate views:HomePage}"
            Route="home" />
        <ShellContent
            Title="Fichas"
            Icon="tab_chips"
            ContentTemplate="{DataTemplate views:ChipsPage}"
            Route="chips" />
        <ShellContent
            Title="Reuniões"
            Icon="tab_meetings"
            ContentTemplate="{DataTemplate views:MeetingsPage}"
            Route="meetings" />
        <ShellContent
            Title="Programa"
            Icon="tab_program"
            ContentTemplate="{DataTemplate views:ProgramPage}"
            Route="program" />
    </TabBar>

</Shell>
