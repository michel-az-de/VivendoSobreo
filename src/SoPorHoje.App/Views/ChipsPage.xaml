<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:SoPorHoje.App.ViewModels"
             xmlns:models="clr-namespace:SoPorHoje.App.Models"
             xmlns:conv="clr-namespace:SoPorHoje.App.Converters"
             x:Class="SoPorHoje.App.Views.ChipsPage"
             x:DataType="vm:ChipsViewModel"
             BackgroundColor="{StaticResource BgPrimary}"
             Title="Fichas">

    <ContentPage.Resources>
        <conv:BoolToOpacityConverter x:Key="BoolToOpacityConverter" />
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,*" Padding="16" RowSpacing="16">

        <!-- Header -->
        <VerticalStackLayout Grid.Row="0" Spacing="8">
            <Label Text="Minhas Fichas"
                   FontSize="24"
                   FontAttributes="Bold"
                   TextColor="{StaticResource TextPrimary}"
                   SemanticProperties.HeadingLevel="Level1" />

            <Label TextColor="{StaticResource TextSecondary}" FontSize="14">
                <Label.FormattedText>
                    <FormattedString>
                        <Span Text="{Binding EarnedCount}" FontAttributes="Bold" TextColor="{StaticResource TextPrimary}" />
                        <Span Text=" de 10 conquistadas" />
                    </FormattedString>
                </Label.FormattedText>
            </Label>

            <ProgressBar Progress="{Binding OverallProgress}"
                         ProgressColor="{StaticResource Accent}"
                         HeightRequest="8" />
        </VerticalStackLayout>

        <!-- Chips list -->
        <CollectionView Grid.Row="1"
                         ItemsSource="{Binding Chips}">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:SobrietyChip">
                    <Border StrokeThickness="1"
                            Stroke="{StaticResource BgBorder}"
                            BackgroundColor="{StaticResource BgSurface}"
                            Padding="14,16"
                            Margin="0,4"
                            StrokeShape="RoundRectangle 16"
                            Opacity="{Binding IsEarned, Converter={StaticResource BoolToOpacityConverter}}">
                        <Grid ColumnDefinitions="56,*,Auto" ColumnSpacing="12">
                            <!-- Emoji -->
                            <Frame Grid.Column="0"
                                   WidthRequest="48"
                                   HeightRequest="48"
                                   CornerRadius="24"
                                   BackgroundColor="{StaticResource BgSurfaceLight}"
                                   Padding="0"
                                   HasShadow="False"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center">
                                <Label Text="{Binding Emoji}"
                                       FontSize="24"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center" />
                            </Frame>

                            <!-- Info -->
                            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                                <Label Text="{Binding Name}"
                                       FontSize="16"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource TextPrimary}" />
                                <Label Text="{Binding Label}"
                                       FontSize="13"
                                       TextColor="{StaticResource TextSecondary}" />
                                <Label FontSize="12" TextColor="{StaticResource TextMuted}">
                                    <Label.FormattedText>
                                        <FormattedString>
                                            <Span Text="{Binding RequiredDays}" />
                                            <Span Text=" dias" />
                                        </FormattedString>
                                    </Label.FormattedText>
                                </Label>
                            </VerticalStackLayout>

                            <!-- Status -->
                            <Label Grid.Column="2"
                                   VerticalOptions="Center"
                                   FontSize="20"
                                   HorizontalOptions="End">
                                <Label.Triggers>
                                    <DataTrigger TargetType="Label"
                                                 Binding="{Binding IsEarned}"
                                                 Value="True">
                                        <Setter Property="Text" Value="&#x2705;" />
                                    </DataTrigger>
                                    <DataTrigger TargetType="Label"
                                                 Binding="{Binding IsEarned}"
                                                 Value="False">
                                        <Setter Property="Text" Value="&#x1F512;" />
                                    </DataTrigger>
                                </Label.Triggers>
                            </Label>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </Grid>

</ContentPage>
