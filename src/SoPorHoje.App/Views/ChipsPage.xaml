<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:SoPorHoje.App.ViewModels"
             xmlns:models="clr-namespace:SoPorHoje.App.Models"
             xmlns:conv="clr-namespace:SoPorHoje.App.Converters"
             x:Class="SoPorHoje.App.Views.ChipsPage"
             x:DataType="vm:ChipsViewModel"
             BackgroundColor="#0C1219"
             Shell.NavBarIsVisible="False"
             Title="Fichas">

    <ContentPage.Resources>
        <conv:BoolToOpacityConverter x:Key="BoolToOpacityConverter" />
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,*" RowSpacing="0">

        <!-- Header -->
        <VerticalStackLayout Grid.Row="0" Spacing="6" Margin="16,8,16,12">
            <Label Text="Minhas Fichas"
                   FontSize="22" FontAttributes="Bold"
                   TextColor="#E2E8F0" />

            <Label TextColor="#8A9AAE" FontSize="14">
                <Label.FormattedText>
                    <FormattedString>
                        <Span Text="{Binding EarnedCount}" FontAttributes="Bold" TextColor="#E2E8F0" />
                        <Span Text=" de 10 conquistadas" />
                    </FormattedString>
                </Label.FormattedText>
            </Label>

            <Border HeightRequest="4" Margin="0,4,0,0"
                    StrokeThickness="0"
                    BackgroundColor="#1D2C3C"
                    StrokeShape="RoundRectangle 2,2,2,2">
                <ProgressBar Progress="{Binding OverallProgress}"
                             ProgressColor="#3A8AC5"
                             HeightRequest="4" />
            </Border>
        </VerticalStackLayout>

        <!-- Chips list -->
        <CollectionView Grid.Row="1"
                         ItemsSource="{Binding Chips}">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:SobrietyChip">
                    <Border Stroke="#1D2C3C" StrokeThickness="1"
                            BackgroundColor="#131D28"
                            Padding="14"
                            Margin="16,0,16,8"
                            StrokeShape="RoundRectangle 16,16,16,16"
                            Opacity="{Binding IsEarned, Converter={StaticResource BoolToOpacityConverter}}">
                        <Grid ColumnDefinitions="52,*,Auto" ColumnSpacing="12">
                            <!-- Chip badge with color -->
                            <Frame Grid.Column="0"
                                   WidthRequest="44" HeightRequest="44"
                                   CornerRadius="22"
                                   BackgroundColor="{Binding BgColor}"
                                   BorderColor="{Binding ChipColor}"
                                   Padding="0" HasShadow="False"
                                   HorizontalOptions="Center" VerticalOptions="Center">
                                <Label Text="{Binding ShortLabel}"
                                       FontSize="14" FontAttributes="Bold"
                                       TextColor="{Binding ChipColor}"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center"
                                       HorizontalTextAlignment="Center"
                                       VerticalTextAlignment="Center" />
                            </Frame>

                            <!-- Info -->
                            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                                <Label Text="{Binding Name}"
                                       FontSize="15" FontAttributes="Bold"
                                       TextColor="#E2E8F0" />
                                <Label Text="{Binding Label}"
                                       FontSize="12" TextColor="#8A9AAE" />
                                <Label FontSize="11" TextColor="#49596B">
                                    <Label.FormattedText>
                                        <FormattedString>
                                            <Span Text="{Binding RequiredDays}" />
                                            <Span Text=" dias" />
                                        </FormattedString>
                                    </Label.FormattedText>
                                </Label>
                            </VerticalStackLayout>

                            <!-- Status -->
                            <Label Grid.Column="2"
                                   VerticalOptions="Center"
                                   FontSize="18"
                                   HorizontalOptions="End">
                                <Label.Triggers>
                                    <DataTrigger TargetType="Label"
                                                 Binding="{Binding IsEarned}"
                                                 Value="True">
                                        <Setter Property="Text" Value="&#x2705;" />
                                    </DataTrigger>
                                    <DataTrigger TargetType="Label"
                                                 Binding="{Binding IsEarned}"
                                                 Value="False">
                                        <Setter Property="Text" Value="&#x1F512;" />
                                    </DataTrigger>
                                </Label.Triggers>
                            </Label>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </Grid>

</ContentPage>
