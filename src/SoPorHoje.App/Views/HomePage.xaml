<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:SoPorHoje.App.ViewModels"
             xmlns:conv="clr-namespace:SoPorHoje.App.Converters"
             x:Class="SoPorHoje.App.Views.HomePage"
             x:DataType="vm:HomeViewModel"
             BackgroundColor="#0C1219"
             Shell.NavBarIsVisible="False"
             Title="Só Por Hoje">

    <ContentPage.Resources>
        <conv:InverseBoolConverter x:Key="InverseBoolConverter" />
        <conv:StringToBoolConverter x:Key="StringToBoolConverter" />
    </ContentPage.Resources>

    <ScrollView>
        <VerticalStackLayout Padding="0,12,0,30" Spacing="0">

            <!-- a) Live meeting banner -->
            <Border Stroke="#1A2E1F" StrokeThickness="1"
                    BackgroundColor="#0F1A13"
                    IsVisible="{Binding HasLiveMeeting}"
                    Padding="14,12"
                    Margin="16,0,16,10"
                    StrokeShape="RoundRectangle 14,14,14,14">
                <HorizontalStackLayout Spacing="10" VerticalOptions="Center">
                    <Frame WidthRequest="10" HeightRequest="10" CornerRadius="5"
                           BackgroundColor="#27AE60" Padding="0" HasShadow="False"
                           VerticalOptions="Center" />
                    <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="FillAndExpand" Spacing="0">
                        <Label Text="{Binding LiveMeetingName}"
                               TextColor="#E2E8F0" FontSize="14" />
                        <Label Text="{Binding LiveMeetingEndTime, StringFormat='até {0}'}"
                               TextColor="#27AE60" FontSize="11" />
                    </VerticalStackLayout>
                    <Button Text="Entrar"
                            BackgroundColor="#27AE60" TextColor="White"
                            CornerRadius="12" HeightRequest="36" FontSize="13"
                            FontAttributes="Bold" Padding="14,0"
                            Command="{Binding JoinLiveMeetingCommand}" />
                </HorizontalStackLayout>
            </Border>

            <!-- Next meeting banner -->
            <Border Stroke="#1D2C3C" StrokeThickness="1"
                    BackgroundColor="#131D28"
                    IsVisible="{Binding HasNextMeeting}"
                    Padding="14,12"
                    Margin="16,0,16,10"
                    StrokeShape="RoundRectangle 14,14,14,14">
                <Label TextColor="#8A9AAE" FontSize="13">
                    <Label.FormattedText>
                        <FormattedString>
                            <Span Text="Próxima: " />
                            <Span Text="{Binding NextMeetingName}" FontAttributes="Bold" TextColor="#E2E8F0" />
                            <Span Text=" em " />
                            <Span Text="{Binding NextMeetingMinutes}" FontAttributes="Bold" TextColor="#E2E8F0" />
                            <Span Text=" min" />
                        </FormattedString>
                    </Label.FormattedText>
                </Label>
            </Border>

            <!-- b) Counter section — hero area -->
            <VerticalStackLayout HorizontalOptions="Center" Spacing="4" Margin="0,20,0,12">

                <!-- Chip badge circular com cor da ficha -->
                <Frame WidthRequest="56" HeightRequest="56" CornerRadius="28"
                       Padding="0" HasShadow="False"
                       BackgroundColor="#131D28"
                       BorderColor="{Binding CurrentChipColor}"
                       HorizontalOptions="Center">
                    <Label Text="{Binding CurrentChipEmoji}"
                           FontSize="16" FontAttributes="Bold"
                           TextColor="{Binding CurrentChipColor}"
                           HorizontalOptions="Center" VerticalOptions="Center"
                           HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                </Frame>

                <!-- Número GIGANTE -->
                <Label Text="{Binding SoberDays}"
                       FontSize="64" FontAttributes="Bold"
                       TextColor="#E2E8F0"
                       HorizontalTextAlignment="Center"
                       Margin="0,4,0,0" />

                <!-- Subtítulo -->
                <Label TextColor="#8A9AAE" FontSize="14" HorizontalTextAlignment="Center">
                    <Label.FormattedText>
                        <FormattedString>
                            <Span Text="{Binding SoberDays, StringFormat='{0} dias sóbrios'}" />
                            <Span Text=" · " />
                            <Span Text="{Binding SoberMonths}" />
                        </FormattedString>
                    </Label.FormattedText>
                </Label>

                <!-- Chip name -->
                <Label Text="{Binding CurrentChipName}"
                       FontSize="12" TextColor="#49596B"
                       HorizontalTextAlignment="Center" Margin="0,2,0,0" />

                <!-- Editar data -->
                <Label Text="editar data"
                       FontSize="10" TextColor="#49596B"
                       TextDecorations="Underline"
                       HorizontalTextAlignment="Center" Margin="0,4,0,0">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding EditSobrietyDateCommand}" />
                    </Label.GestureRecognizers>
                </Label>

                <!-- Progress bar para próxima ficha -->
                <Grid Margin="40,10,40,0" RowDefinitions="Auto,Auto" ColumnDefinitions="*,Auto" ColumnSpacing="8">
                    <Label FontSize="10" TextColor="#49596B">
                        <Label.FormattedText>
                            <FormattedString>
                                <Span Text="Próxima: " />
                                <Span Text="{Binding NextChipName}" />
                            </FormattedString>
                        </Label.FormattedText>
                    </Label>
                    <Label Grid.Column="1"
                           Text="{Binding DaysToNextChip, StringFormat='{0}d'}"
                           FontSize="10" TextColor="#49596B" />

                    <Border Grid.Row="1" Grid.ColumnSpan="2"
                            HeightRequest="4" Margin="0,4,0,0"
                            StrokeThickness="0"
                            BackgroundColor="#1D2C3C"
                            StrokeShape="RoundRectangle 2,2,2,2">
                        <ProgressBar Progress="{Binding ProgressToNextChip}"
                                     ProgressColor="#3A8AC5"
                                     HeightRequest="4" />
                    </Border>
                </Grid>
            </VerticalStackLayout>

            <!-- c) SOS Button — destaque vermelho -->
            <Border Stroke="#2A1215" StrokeThickness="1"
                    BackgroundColor="#150D0E"
                    Padding="14"
                    Margin="16,0,16,10"
                    StrokeShape="RoundRectangle 14,14,14,14">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding OpenSOSCommand}" />
                </Border.GestureRecognizers>
                <HorizontalStackLayout HorizontalOptions="Center" Spacing="8">
                    <Label Text="&#x1F198;" FontSize="16" VerticalOptions="Center" />
                    <Label Text="Preciso de ajuda agora"
                           TextColor="#C0392B" FontSize="14" FontAttributes="Bold"
                           VerticalOptions="Center" />
                </HorizontalStackLayout>
            </Border>

            <!-- d) Daily pledge — NÃO fez ainda -->
            <Border Stroke="#1A2E1F" StrokeThickness="1"
                    BackgroundColor="#0F1A13"
                    Padding="16"
                    Margin="16,0,16,10"
                    StrokeShape="RoundRectangle 16,16,16,16"
                    IsVisible="{Binding HasPledgedToday, Converter={StaticResource InverseBoolConverter}}">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding MakePledgeCommand}" />
                </Border.GestureRecognizers>
                <VerticalStackLayout HorizontalOptions="Center" Spacing="6">
                    <Label Text="&#x270B; Só por hoje, eu não vou beber"
                           FontSize="16" FontAttributes="Bold" TextColor="#27AE60"
                           HorizontalTextAlignment="Center" />
                    <Label Text="Toque para fazer seu compromisso"
                           FontSize="12" TextColor="#8A9AAE"
                           HorizontalTextAlignment="Center" />
                </VerticalStackLayout>
            </Border>

            <!-- Daily pledge — JÁ fez -->
            <Border Stroke="#1A2E1F" StrokeThickness="1"
                    BackgroundColor="#111D17"
                    Padding="14"
                    Margin="16,0,16,10"
                    StrokeShape="RoundRectangle 16,16,16,16"
                    IsVisible="{Binding HasPledgedToday}">
                <VerticalStackLayout HorizontalOptions="Center" Spacing="4">
                    <Label Text="&#x2705; Compromisso feito hoje"
                           FontSize="14" FontAttributes="Bold" TextColor="#27AE60"
                           HorizontalTextAlignment="Center" />
                    <Label Text="&quot;Só por hoje, eu não vou beber.&quot;"
                           FontSize="12" TextColor="#49596B" FontAttributes="Italic"
                           HorizontalTextAlignment="Center" />
                </VerticalStackLayout>
            </Border>

            <!-- e) Personal reason — quando está VAZIO -->
            <Border Stroke="#1D2C3C" StrokeThickness="1"
                    BackgroundColor="#131D28" Padding="16,14"
                    Margin="16,0,16,10"
                    StrokeShape="RoundRectangle 16,16,16,16"
                    IsVisible="{Binding IsReasonEditing}">
                <VerticalStackLayout Spacing="8">
                    <Label Text="&#x1F511; MEU MOTIVO" FontSize="11" FontAttributes="Bold"
                           TextColor="#D4A017" CharacterSpacing="1" />
                    <Label Text="Por que você parou de beber? Escreva aqui. Quando a fissura bater, releia."
                           FontSize="12" TextColor="#8A9AAE" LineHeight="1.4" />
                    <Editor Placeholder="Ex: Pela minha filha. Para ter uma vida de verdade."
                            PlaceholderColor="#49596B"
                            TextColor="#E2E8F0" FontSize="14"
                            BackgroundColor="#0C1219"
                            HeightRequest="60"
                            Text="{Binding PersonalReason}" />
                    <Button Text="Salvar"
                            BackgroundColor="#3A8AC5" TextColor="White"
                            CornerRadius="10" HeightRequest="40"
                            FontSize="13" FontAttributes="Bold"
                            HorizontalOptions="End"
                            Command="{Binding SaveReasonCommand}" />
                </VerticalStackLayout>
            </Border>

            <!-- Personal reason — quando está PREENCHIDO (não editando) -->
            <Border Stroke="#1D2C3C" StrokeThickness="1"
                    BackgroundColor="#131D28" Padding="16,14"
                    Margin="16,0,16,10"
                    StrokeShape="RoundRectangle 16,16,16,16"
                    IsVisible="{Binding IsReasonEditing, Converter={StaticResource InverseBoolConverter}}">
                <VerticalStackLayout Spacing="6">
                    <!-- Tem motivo salvo -->
                    <VerticalStackLayout Spacing="6"
                                         IsVisible="{Binding PersonalReason, Converter={StaticResource StringToBoolConverter}}">
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Text="&#x1F511; MEU MOTIVO" FontSize="11" FontAttributes="Bold"
                                   TextColor="#D4A017" CharacterSpacing="1" />
                            <Label Grid.Column="1" Text="editar" FontSize="10" TextColor="#49596B">
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding ToggleReasonEditCommand}" />
                                </Label.GestureRecognizers>
                            </Label>
                        </Grid>
                        <Label Text="{Binding PersonalReason, StringFormat='&quot;{0}&quot;'}"
                               FontSize="15" TextColor="#E2E8F0" FontAttributes="Italic"
                               LineHeight="1.5" />
                    </VerticalStackLayout>

                    <!-- Não tem motivo ainda -->
                    <VerticalStackLayout Spacing="8"
                                         IsVisible="{Binding PersonalReason, Converter={StaticResource StringToBoolConverter}, ConverterParameter=invert}">
                        <Label Text="&#x1F511; MEU MOTIVO" FontSize="11" FontAttributes="Bold"
                               TextColor="#D4A017" CharacterSpacing="1" />
                        <Label Text="Por que você quer ficar sóbrio? Anote aqui."
                               FontSize="12" TextColor="#8A9AAE" />
                        <Button Text="Adicionar motivo"
                                BackgroundColor="#3A8AC5" TextColor="White"
                                CornerRadius="10" HeightRequest="40"
                                FontSize="13" FontAttributes="Bold"
                                Command="{Binding ToggleReasonEditCommand}" />
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>

            <!-- f) Daily reflection -->
            <Border Stroke="#1D2C3C" StrokeThickness="1"
                    BackgroundColor="#131D28" Padding="16,14"
                    Margin="16,0,16,10"
                    StrokeShape="RoundRectangle 16,16,16,16">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding ToggleReflectionCommand}" />
                </Border.GestureRecognizers>
                <VerticalStackLayout Spacing="8">
                    <!-- Seção -->
                    <Label Text="REFLEXÃO DO DIA"
                           FontSize="11" FontAttributes="Bold"
                           TextColor="#3A8AC5" CharacterSpacing="1" />

                    <!-- Título -->
                    <Label Text="{Binding ReflectionTitle}"
                           FontSize="17" FontAttributes="Bold"
                           TextColor="#D4A017" LineHeight="1.3" />

                    <!-- Citação -->
                    <Label Text="{Binding ReflectionQuote}"
                           FontAttributes="Italic"
                           TextColor="#8A9AAE" FontSize="13"
                           LineHeight="1.5" />

                    <!-- Referência -->
                    <Label Text="{Binding ReflectionReference}"
                           TextColor="#49596B" FontSize="10" />

                    <!-- Expandir -->
                    <Label Text="&#x25BC; Ler reflexão completa"
                           TextColor="#3A8AC5" FontSize="12"
                           IsVisible="{Binding IsReflectionExpanded, Converter={StaticResource InverseBoolConverter}}"
                           Padding="0,4" />

                    <!-- Texto completo -->
                    <Label Text="{Binding ReflectionText}"
                           TextColor="#8A9AAE" FontSize="13"
                           LineHeight="1.6"
                           IsVisible="{Binding IsReflectionExpanded}" />

                    <!-- Recolher -->
                    <Label Text="&#x25B2; Recolher"
                           TextColor="#3A8AC5" FontSize="12"
                           IsVisible="{Binding IsReflectionExpanded}"
                           Padding="0,4" />
                </VerticalStackLayout>
            </Border>

            <!-- g) Serenity prayer -->
            <Border Stroke="#1D2C3C" StrokeThickness="1"
                    BackgroundColor="#131D28" Padding="16,12"
                    Margin="16,0,16,10"
                    StrokeShape="RoundRectangle 16,16,16,16">
                <VerticalStackLayout Spacing="8">
                    <Label Text="ORAÇÃO DA SERENIDADE"
                           FontSize="10" FontAttributes="Bold"
                           TextColor="#D4A017" CharacterSpacing="1"
                           HorizontalTextAlignment="Center" />
                    <Label Text="{Binding SerenityPrayer}"
                           TextColor="#8A9AAE" FontAttributes="Italic"
                           FontSize="13" HorizontalTextAlignment="Center"
                           LineHeight="1.5" />
                </VerticalStackLayout>
            </Border>

            <!-- h) Literatura rápida -->
            <Border Stroke="#1D2C3C" StrokeThickness="1"
                    BackgroundColor="#131D28" Padding="14"
                    Margin="16,0,16,10"
                    StrokeShape="RoundRectangle 14,14,14,14">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding GoToLiteratureCommand}" />
                </Border.GestureRecognizers>
                <HorizontalStackLayout Spacing="12" VerticalOptions="Center">
                    <Label Text="&#x1F4DA;" FontSize="22" VerticalOptions="Center" />
                    <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="FillAndExpand">
                        <Label Text="Literaturas" FontSize="15" FontAttributes="Bold" TextColor="#E2E8F0" />
                        <Label Text="Sorteio de textos do programa" FontSize="12" TextColor="#8A9AAE" />
                    </VerticalStackLayout>
                    <Label Text="&#x276F;" FontSize="16" TextColor="#49596B" VerticalOptions="Center" />
                </HorizontalStackLayout>
            </Border>

            <!-- i) Como você está hoje? — diário de humor -->
            <Border Stroke="#1D2C3C" StrokeThickness="1"
                    BackgroundColor="#131D28" Padding="16,14"
                    Margin="16,0,16,10"
                    StrokeShape="RoundRectangle 16,16,16,16">
                <VerticalStackLayout Spacing="10">
                    <Label Text="COMO VOCÊ ESTÁ HOJE?"
                           FontSize="11" FontAttributes="Bold"
                           TextColor="#3A8AC5" CharacterSpacing="1" />
                    <Grid ColumnDefinitions="*,*,*,*,*,*" ColumnSpacing="4">
                        <!-- 😊 Bem -->
                        <Border Grid.Column="0" Padding="0" StrokeThickness="2"
                                StrokeShape="RoundRectangle 12">
                            <Border.Triggers>
                                <DataTrigger TargetType="Border" Binding="{Binding TodayMoodEmoji}" Value="😊">
                                    <Setter Property="Stroke" Value="#3A8AC5" />
                                    <Setter Property="BackgroundColor" Value="#0E1E2C" />
                                </DataTrigger>
                                <DataTrigger TargetType="Border" Binding="{Binding TodayMoodEmoji}" Value="">
                                    <Setter Property="Stroke" Value="#1D2C3C" />
                                    <Setter Property="BackgroundColor" Value="Transparent" />
                                </DataTrigger>
                            </Border.Triggers>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SetMoodCommand}" CommandParameter="😊" />
                            </Border.GestureRecognizers>
                            <VerticalStackLayout Spacing="2" Padding="4,6" HorizontalOptions="Center">
                                <Label Text="😊" FontSize="24" HorizontalTextAlignment="Center" />
                                <Label Text="Bem" FontSize="9" TextColor="#8A9AAE" HorizontalTextAlignment="Center" />
                            </VerticalStackLayout>
                        </Border>
                        <!-- 😐 Ok -->
                        <Border Grid.Column="1" Padding="0" StrokeThickness="2"
                                StrokeShape="RoundRectangle 12">
                            <Border.Triggers>
                                <DataTrigger TargetType="Border" Binding="{Binding TodayMoodEmoji}" Value="😐">
                                    <Setter Property="Stroke" Value="#3A8AC5" />
                                    <Setter Property="BackgroundColor" Value="#0E1E2C" />
                                </DataTrigger>
                                <DataTrigger TargetType="Border" Binding="{Binding TodayMoodEmoji}" Value="">
                                    <Setter Property="Stroke" Value="#1D2C3C" />
                                    <Setter Property="BackgroundColor" Value="Transparent" />
                                </DataTrigger>
                            </Border.Triggers>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SetMoodCommand}" CommandParameter="😐" />
                            </Border.GestureRecognizers>
                            <VerticalStackLayout Spacing="2" Padding="4,6" HorizontalOptions="Center">
                                <Label Text="😐" FontSize="24" HorizontalTextAlignment="Center" />
                                <Label Text="Ok" FontSize="9" TextColor="#8A9AAE" HorizontalTextAlignment="Center" />
                            </VerticalStackLayout>
                        </Border>
                        <!-- 😔 Baixo -->
                        <Border Grid.Column="2" Padding="0" StrokeThickness="2"
                                StrokeShape="RoundRectangle 12">
                            <Border.Triggers>
                                <DataTrigger TargetType="Border" Binding="{Binding TodayMoodEmoji}" Value="😔">
                                    <Setter Property="Stroke" Value="#3A8AC5" />
                                    <Setter Property="BackgroundColor" Value="#0E1E2C" />
                                </DataTrigger>
                                <DataTrigger TargetType="Border" Binding="{Binding TodayMoodEmoji}" Value="">
                                    <Setter Property="Stroke" Value="#1D2C3C" />
                                    <Setter Property="BackgroundColor" Value="Transparent" />
                                </DataTrigger>
                            </Border.Triggers>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SetMoodCommand}" CommandParameter="😔" />
                            </Border.GestureRecognizers>
                            <VerticalStackLayout Spacing="2" Padding="4,6" HorizontalOptions="Center">
                                <Label Text="😔" FontSize="24" HorizontalTextAlignment="Center" />
                                <Label Text="Baixo" FontSize="9" TextColor="#8A9AAE" HorizontalTextAlignment="Center" />
                            </VerticalStackLayout>
                        </Border>
                        <!-- 😤 Irritado -->
                        <Border Grid.Column="3" Padding="0" StrokeThickness="2"
                                StrokeShape="RoundRectangle 12">
                            <Border.Triggers>
                                <DataTrigger TargetType="Border" Binding="{Binding TodayMoodEmoji}" Value="😤">
                                    <Setter Property="Stroke" Value="#3A8AC5" />
                                    <Setter Property="BackgroundColor" Value="#0E1E2C" />
                                </DataTrigger>
                                <DataTrigger TargetType="Border" Binding="{Binding TodayMoodEmoji}" Value="">
                                    <Setter Property="Stroke" Value="#1D2C3C" />
                                    <Setter Property="BackgroundColor" Value="Transparent" />
                                </DataTrigger>
                            </Border.Triggers>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SetMoodCommand}" CommandParameter="😤" />
                            </Border.GestureRecognizers>
                            <VerticalStackLayout Spacing="2" Padding="4,6" HorizontalOptions="Center">
                                <Label Text="😤" FontSize="24" HorizontalTextAlignment="Center" />
                                <Label Text="Irritado" FontSize="9" TextColor="#8A9AAE" HorizontalTextAlignment="Center" />
                            </VerticalStackLayout>
                        </Border>
                        <!-- 😰 Ansioso -->
                        <Border Grid.Column="4" Padding="0" StrokeThickness="2"
                                StrokeShape="RoundRectangle 12">
                            <Border.Triggers>
                                <DataTrigger TargetType="Border" Binding="{Binding TodayMoodEmoji}" Value="😰">
                                    <Setter Property="Stroke" Value="#3A8AC5" />
                                    <Setter Property="BackgroundColor" Value="#0E1E2C" />
                                </DataTrigger>
                                <DataTrigger TargetType="Border" Binding="{Binding TodayMoodEmoji}" Value="">
                                    <Setter Property="Stroke" Value="#1D2C3C" />
                                    <Setter Property="BackgroundColor" Value="Transparent" />
                                </DataTrigger>
                            </Border.Triggers>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SetMoodCommand}" CommandParameter="😰" />
                            </Border.GestureRecognizers>
                            <VerticalStackLayout Spacing="2" Padding="4,6" HorizontalOptions="Center">
                                <Label Text="😰" FontSize="24" HorizontalTextAlignment="Center" />
                                <Label Text="Ansioso" FontSize="9" TextColor="#8A9AAE" HorizontalTextAlignment="Center" />
                            </VerticalStackLayout>
                        </Border>
                        <!-- 🙏 Grato -->
                        <Border Grid.Column="5" Padding="0" StrokeThickness="2"
                                StrokeShape="RoundRectangle 12">
                            <Border.Triggers>
                                <DataTrigger TargetType="Border" Binding="{Binding TodayMoodEmoji}" Value="🙏">
                                    <Setter Property="Stroke" Value="#3A8AC5" />
                                    <Setter Property="BackgroundColor" Value="#0E1E2C" />
                                </DataTrigger>
                                <DataTrigger TargetType="Border" Binding="{Binding TodayMoodEmoji}" Value="">
                                    <Setter Property="Stroke" Value="#1D2C3C" />
                                    <Setter Property="BackgroundColor" Value="Transparent" />
                                </DataTrigger>
                            </Border.Triggers>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SetMoodCommand}" CommandParameter="🙏" />
                            </Border.GestureRecognizers>
                            <VerticalStackLayout Spacing="2" Padding="4,6" HorizontalOptions="Center">
                                <Label Text="🙏" FontSize="24" HorizontalTextAlignment="Center" />
                                <Label Text="Grato" FontSize="9" TextColor="#8A9AAE" HorizontalTextAlignment="Center" />
                            </VerticalStackLayout>
                        </Border>
                    </Grid>
                    <!-- Humor salvo -->
                    <Label IsVisible="{Binding TodayMoodEmoji, Converter={StaticResource StringToBoolConverter}}"
                           FontSize="12" TextColor="#49596B" HorizontalTextAlignment="Center">
                        <Label.FormattedText>
                            <FormattedString>
                                <Span Text="{Binding TodayMoodEmoji}" />
                                <Span Text=" " />
                                <Span Text="{Binding TodayMoodLabel}" TextColor="#8A9AAE" />
                                <Span Text=" · registrado hoje" />
                            </FormattedString>
                        </Label.FormattedText>
                    </Label>
                </VerticalStackLayout>
            </Border>

            <!-- j) Footer -->
            <Label Text="EVITE O PRIMEIRO GOLE"
                   FontSize="11" TextColor="#49596B"
                   HorizontalTextAlignment="Center"
                   CharacterSpacing="2"
                   Margin="0,8,0,0" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
