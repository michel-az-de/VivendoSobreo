<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:SoPorHoje.App.ViewModels"
             x:Class="SoPorHoje.App.Views.JustForTodayPage"
             x:DataType="vm:JustForTodayViewModel"
             BackgroundColor="{StaticResource BgPrimary}"
             Title="Só Por Hoje">

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="12">

            <Label Text="Só Por Hoje"
                   FontSize="24"
                   FontAttributes="Bold"
                   TextColor="{StaticResource TextPrimary}"
                   SemanticProperties.HeadingLevel="Level1" />

            <CollectionView ItemsSource="{Binding Items}">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="vm:JustForTodayItem">
                        <Border StrokeThickness="1"
                                Stroke="{StaticResource BgBorder}"
                                BackgroundColor="{StaticResource BgSurface}"
                                Padding="14,16"
                                Margin="0,4"
                                StrokeShape="RoundRectangle 16">
                            <VerticalStackLayout Spacing="6">
                                <Label TextColor="{StaticResource Warm}"
                                       FontSize="12"
                                       FontAttributes="Bold">
                                    <Label.FormattedText>
                                        <FormattedString>
                                            <Span Text="{Binding Number}" />
                                            <Span Text="." />
                                        </FormattedString>
                                    </Label.FormattedText>
                                </Label>
                                <Label Text="{Binding Text}"
                                       TextColor="{StaticResource TextPrimary}"
                                       FontSize="15"
                                       LineHeight="1.4" />
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <BoxView HeightRequest="16" Color="Transparent" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
