<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:SoPorHoje.App.ViewModels"
             x:Class="SoPorHoje.App.Views.JustForTodayPage"
             x:DataType="vm:JustForTodayViewModel"
             BackgroundColor="#0C1219"
             Title="Só Por Hoje">

    <ScrollView>
        <VerticalStackLayout Padding="0,8,0,24" Spacing="0">

            <Label Text="Só Por Hoje"
                   FontSize="22" FontAttributes="Bold"
                   TextColor="#E2E8F0"
                   Margin="16,8,16,12" />

            <CollectionView ItemsSource="{Binding Items}">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="vm:JustForTodayItem">
                        <Border Stroke="#1D2C3C" StrokeThickness="1"
                                BackgroundColor="#131D28"
                                Padding="14"
                                Margin="16,0,16,8"
                                StrokeShape="RoundRectangle 16,16,16,16">
                            <VerticalStackLayout Spacing="6">
                                <Label TextColor="#D4A017" FontSize="12" FontAttributes="Bold">
                                    <Label.FormattedText>
                                        <FormattedString>
                                            <Span Text="{Binding Number}" />
                                            <Span Text="." />
                                        </FormattedString>
                                    </Label.FormattedText>
                                </Label>
                                <Label Text="{Binding Text}"
                                       TextColor="#E2E8F0" FontSize="14"
                                       LineHeight="1.4" />
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
