<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:SoPorHoje.App.ViewModels"
             xmlns:sys="clr-namespace:System;assembly=System.Runtime"
             x:Class="SoPorHoje.App.Views.OnboardingPage"
             x:DataType="vm:OnboardingViewModel"
             BackgroundColor="#0C1219"
             Shell.NavBarIsVisible="False">

    <ScrollView>
        <VerticalStackLayout Spacing="20"
                             Padding="24"
                             VerticalOptions="Center"
                             HorizontalOptions="Center"
                             MaximumWidthRequest="360">

            <!-- Logo -->
            <Frame CornerRadius="36"
                   HeightRequest="72" WidthRequest="72"
                   BackgroundColor="#3A8AC5"
                   Padding="0" HasShadow="False"
                   HorizontalOptions="Center">
                <Label Text="&#x1F54A;&#xFE0F;"
                       FontSize="36"
                       HorizontalOptions="Center"
                       VerticalOptions="Center" />
            </Frame>

            <!-- Title -->
            <Label Text="Só Por Hoje"
                   FontSize="28" FontAttributes="Bold"
                   TextColor="#E2E8F0"
                   HorizontalTextAlignment="Center" />

            <!-- Subtitle -->
            <Label Text="Seu companheiro na jornada de sobriedade"
                   TextColor="#8A9AAE"
                   HorizontalTextAlignment="Center"
                   FontSize="15" />

            <BoxView HeightRequest="20" Color="Transparent" />

            <!-- Date label -->
            <Label Text="QUANDO FOI SEU ÚLTIMO GOLE?"
                   FontSize="11" TextColor="#8A9AAE"
                   CharacterSpacing="2"
                   HorizontalTextAlignment="Center" />

            <!-- DatePicker -->
            <DatePicker Date="{Binding SelectedDate}"
                        MaximumDate="{x:Static sys:DateTime.Today}"
                        TextColor="#E2E8F0"
                        HorizontalOptions="Center" />

            <!-- Privacy note -->
            <Label Text="Seus dados ficam apenas neste dispositivo."
                   FontSize="11" TextColor="#49596B"
                   HorizontalTextAlignment="Center" />

            <!-- Start button -->
            <Button Text="Começar"
                    BackgroundColor="#3A8AC5" TextColor="White"
                    Command="{Binding StartCommand}"
                    IsEnabled="{Binding IsDateSelected}"
                    CornerRadius="14" HeightRequest="48"
                    FontSize="16" FontAttributes="Bold" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
