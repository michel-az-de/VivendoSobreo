<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:SoPorHoje.App.ViewModels"
             x:Class="SoPorHoje.App.Views.PrayersPage"
             x:DataType="vm:PrayersViewModel"
             BackgroundColor="#0C1219"
             Title="Orações">

    <ScrollView>
        <VerticalStackLayout Padding="0,8,0,24" Spacing="0">

            <Label Text="Orações"
                   FontSize="22" FontAttributes="Bold"
                   TextColor="#E2E8F0"
                   Margin="16,8,16,12" />

            <CollectionView ItemsSource="{Binding Prayers}">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="vm:PrayerItem">
                        <Border Stroke="#1D2C3C" StrokeThickness="1"
                                BackgroundColor="#131D28"
                                Padding="16,14"
                                Margin="16,0,16,10"
                                StrokeShape="RoundRectangle 16,16,16,16">
                            <VerticalStackLayout Spacing="10">
                                <Label Text="{Binding Name}"
                                       FontSize="15" FontAttributes="Bold"
                                       TextColor="#D4A017" />
                                <Label Text="{Binding Text}"
                                       TextColor="#E2E8F0" FontSize="14"
                                       LineHeight="1.5" />
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
