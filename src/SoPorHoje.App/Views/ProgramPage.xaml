<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:SoPorHoje.App.ViewModels"
             x:Class="SoPorHoje.App.Views.ProgramPage"
             x:DataType="vm:ProgramViewModel"
             BackgroundColor="#0C1219"
             Shell.NavBarIsVisible="False"
             Title="Programa">

    <ScrollView>
        <VerticalStackLayout Padding="0,12,0,30" Spacing="0">

            <Label Text="Programa"
                   FontSize="22" FontAttributes="Bold"
                   TextColor="#E2E8F0"
                   Margin="16,0,16,12" />

            <!-- Literaturas (destaque) -->
            <Border Stroke="#1D2C3C" StrokeThickness="1"
                    BackgroundColor="#131D28"
                    Padding="14"
                    Margin="16,0,16,10"
                    StrokeShape="RoundRectangle 14,14,14,14">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding GoToLiteratureCommand}" />
                </Border.GestureRecognizers>
                <HorizontalStackLayout Spacing="12" VerticalOptions="Center">
                    <Label Text="&#x1F4DA;" FontSize="28" VerticalOptions="Center" />
                    <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="FillAndExpand">
                        <Label Text="Literaturas" FontSize="15" FontAttributes="Bold" TextColor="#E2E8F0" />
                        <Label Text="Textos do programa — sorteio" FontSize="12" TextColor="#8A9AAE" />
                    </VerticalStackLayout>
                    <Label Text="&#x276F;" FontSize="16" TextColor="#49596B" VerticalOptions="Center" />
                </HorizontalStackLayout>
            </Border>

            <!-- 12 Passos -->
            <Border Stroke="#1D2C3C" StrokeThickness="1"
                    BackgroundColor="#131D28" Padding="14"
                    Margin="16,0,16,10"
                    StrokeShape="RoundRectangle 14,14,14,14">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding GoToStepsCommand}" />
                </Border.GestureRecognizers>
                <HorizontalStackLayout Spacing="12" VerticalOptions="Center">
                    <Label Text="&#x1F4D6;" FontSize="28" VerticalOptions="Center" />
                    <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="FillAndExpand">
                        <Label Text="12 Passos" FontSize="15" FontAttributes="Bold" TextColor="#E2E8F0" />
                        <Label Text="Os passos da recuperação" FontSize="12" TextColor="#8A9AAE" />
                    </VerticalStackLayout>
                    <Label Text="&#x276F;" FontSize="16" TextColor="#49596B" VerticalOptions="Center" />
                </HorizontalStackLayout>
            </Border>

            <!-- 12 Tradições -->
            <Border Stroke="#1D2C3C" StrokeThickness="1"
                    BackgroundColor="#131D28" Padding="14"
                    Margin="16,0,16,10"
                    StrokeShape="RoundRectangle 14,14,14,14">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding GoToTraditionsCommand}" />
                </Border.GestureRecognizers>
                <HorizontalStackLayout Spacing="12" VerticalOptions="Center">
                    <Label Text="&#x1F4DC;" FontSize="28" VerticalOptions="Center" />
                    <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="FillAndExpand">
                        <Label Text="12 Tradições" FontSize="15" FontAttributes="Bold" TextColor="#E2E8F0" />
                        <Label Text="As tradições da irmandade" FontSize="12" TextColor="#8A9AAE" />
                    </VerticalStackLayout>
                    <Label Text="&#x276F;" FontSize="16" TextColor="#49596B" VerticalOptions="Center" />
                </HorizontalStackLayout>
            </Border>

            <!-- Promessas -->
            <Border Stroke="#1D2C3C" StrokeThickness="1"
                    BackgroundColor="#131D28" Padding="14"
                    Margin="16,0,16,10"
                    StrokeShape="RoundRectangle 14,14,14,14">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding GoToPromisesCommand}" />
                </Border.GestureRecognizers>
                <HorizontalStackLayout Spacing="12" VerticalOptions="Center">
                    <Label Text="&#x1F31F;" FontSize="28" VerticalOptions="Center" />
                    <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="FillAndExpand">
                        <Label Text="Promessas" FontSize="15" FontAttributes="Bold" TextColor="#E2E8F0" />
                        <Label Text="As promessas de A.A." FontSize="12" TextColor="#8A9AAE" />
                    </VerticalStackLayout>
                    <Label Text="&#x276F;" FontSize="16" TextColor="#49596B" VerticalOptions="Center" />
                </HorizontalStackLayout>
            </Border>

            <!-- Só Por Hoje -->
            <Border Stroke="#1D2C3C" StrokeThickness="1"
                    BackgroundColor="#131D28" Padding="14"
                    Margin="16,0,16,10"
                    StrokeShape="RoundRectangle 14,14,14,14">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding GoToJustForTodayCommand}" />
                </Border.GestureRecognizers>
                <HorizontalStackLayout Spacing="12" VerticalOptions="Center">
                    <Label Text="&#x1F305;" FontSize="28" VerticalOptions="Center" />
                    <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="FillAndExpand">
                        <Label Text="Só Por Hoje" FontSize="15" FontAttributes="Bold" TextColor="#E2E8F0" />
                        <Label Text="Meditações diárias" FontSize="12" TextColor="#8A9AAE" />
                    </VerticalStackLayout>
                    <Label Text="&#x276F;" FontSize="16" TextColor="#49596B" VerticalOptions="Center" />
                </HorizontalStackLayout>
            </Border>

            <!-- Orações -->
            <Border Stroke="#1D2C3C" StrokeThickness="1"
                    BackgroundColor="#131D28" Padding="14"
                    Margin="16,0,16,10"
                    StrokeShape="RoundRectangle 14,14,14,14">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding GoToPrayersCommand}" />
                </Border.GestureRecognizers>
                <HorizontalStackLayout Spacing="12" VerticalOptions="Center">
                    <Label Text="&#x1F64F;" FontSize="28" VerticalOptions="Center" />
                    <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="FillAndExpand">
                        <Label Text="Orações" FontSize="15" FontAttributes="Bold" TextColor="#E2E8F0" />
                        <Label Text="Orações do programa" FontSize="12" TextColor="#8A9AAE" />
                    </VerticalStackLayout>
                    <Label Text="&#x276F;" FontSize="16" TextColor="#49596B" VerticalOptions="Center" />
                </HorizontalStackLayout>
            </Border>

            <!-- Check HALT -->
            <Border Stroke="#1D2C3C" StrokeThickness="1"
                    BackgroundColor="#131D28" Padding="14"
                    Margin="16,0,16,10"
                    StrokeShape="RoundRectangle 14,14,14,14">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding GoToHaltCheckCommand}" />
                </Border.GestureRecognizers>
                <HorizontalStackLayout Spacing="12" VerticalOptions="Center">
                    <Label Text="&#x1F6A6;" FontSize="28" VerticalOptions="Center" />
                    <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="FillAndExpand">
                        <Label Text="Check HALT" FontSize="15" FontAttributes="Bold" TextColor="#E2E8F0" />
                        <Label Text="Fome, Raiva, Solidão, Cansaço" FontSize="12" TextColor="#8A9AAE" />
                    </VerticalStackLayout>
                    <Label Text="&#x276F;" FontSize="16" TextColor="#49596B" VerticalOptions="Center" />
                </HorizontalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
