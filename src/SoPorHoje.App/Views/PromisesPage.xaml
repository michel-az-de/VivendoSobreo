<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:SoPorHoje.App.ViewModels"
             x:Class="SoPorHoje.App.Views.PromisesPage"
             x:DataType="vm:PromisesViewModel"
             BackgroundColor="#0C1219"
             Title="Promessas">

    <ScrollView>
        <VerticalStackLayout Padding="0,8,0,24" Spacing="0">

            <Label Text="As Promessas"
                   FontSize="22" FontAttributes="Bold"
                   TextColor="#E2E8F0"
                   Margin="16,8,16,4" />

            <Label Text="Se nos empenharmos nesta fase de nosso desenvolvimento, ficaremos admirados antes de chegar à metade do caminho."
                   TextColor="#8A9AAE" FontSize="13"
                   FontAttributes="Italic"
                   Margin="16,0,16,12"
                   LineHeight="1.4" />

            <CollectionView ItemsSource="{Binding Promises}">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="vm:PromiseItem">
                        <Border Stroke="#1D2C3C" StrokeThickness="1"
                                BackgroundColor="#131D28"
                                Padding="0"
                                Margin="16,0,16,8"
                                StrokeShape="RoundRectangle 16,16,16,16">
                            <HorizontalStackLayout Spacing="0">
                                <BoxView WidthRequest="3" Color="#D4A017" VerticalOptions="Fill" />
                                <Label Text="{Binding Text}"
                                       TextColor="#E2E8F0" FontSize="14"
                                       Padding="14,14"
                                       LineHeight="1.4"
                                       VerticalOptions="Center" />
                            </HorizontalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
