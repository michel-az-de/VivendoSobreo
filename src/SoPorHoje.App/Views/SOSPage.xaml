<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:SoPorHoje.App.ViewModels"
             xmlns:conv="clr-namespace:SoPorHoje.App.Converters"
             x:Class="SoPorHoje.App.Views.SOSPage"
             x:DataType="vm:SOSViewModel"
             BackgroundColor="#0C1219"
             Shell.NavBarIsVisible="False"
             Title="SOS">

    <ContentPage.Resources>
        <conv:InverseBoolConverter x:Key="InverseBoolConverter" />
    </ContentPage.Resources>

    <ScrollView>
        <VerticalStackLayout Padding="0,8,0,24" Spacing="0">

            <!-- Header with close button -->
            <Grid ColumnDefinitions="*,Auto" Margin="16,8,16,8">
                <Label Grid.Column="0"
                       Text="Momento difícil?"
                       FontSize="22" FontAttributes="Bold"
                       TextColor="#E2E8F0" VerticalOptions="Center" />
                <Button Grid.Column="1"
                        Text="&#x2715;"
                        BackgroundColor="Transparent"
                        TextColor="#8A9AAE" FontSize="20"
                        HeightRequest="44" WidthRequest="44"
                        Command="{Binding CloseCommand}" />
            </Grid>

            <Label Text="A fissura dura 15–20 minutos."
                   TextColor="#8A9AAE" FontSize="14"
                   Margin="16,0,16,12" />

            <!-- Breathing section -->
            <Border Stroke="#1D2C3C" StrokeThickness="1"
                    BackgroundColor="#131D28"
                    Padding="16,14"
                    Margin="16,0,16,10"
                    StrokeShape="RoundRectangle 16,16,16,16">
                <VerticalStackLayout Spacing="12">
                    <Button Text="&#x1FAC1; Respiração Guiada"
                            BackgroundColor="#3A8AC5" TextColor="White"
                            CornerRadius="14" HeightRequest="48"
                            FontSize="15" FontAttributes="Bold"
                            Command="{Binding StartBreathingCommand}"
                            IsVisible="{Binding IsBreathing, Converter={StaticResource InverseBoolConverter}}" />

                    <!-- Breathing active -->
                    <VerticalStackLayout Spacing="10"
                                         IsVisible="{Binding IsBreathing}"
                                         HorizontalOptions="Center">
                        <Label Text="{Binding BreathingPhase}"
                               FontSize="22" FontAttributes="Bold"
                               TextColor="#E2E8F0"
                               HorizontalTextAlignment="Center" />
                        <Label Text="{Binding BreathingCounter}"
                               FontSize="48" FontAttributes="Bold"
                               TextColor="#3A8AC5"
                               HorizontalTextAlignment="Center" />

                        <Border HeightRequest="4" Margin="20,0"
                                StrokeThickness="0"
                                BackgroundColor="#1D2C3C"
                                StrokeShape="RoundRectangle 2,2,2,2">
                            <ProgressBar Progress="{Binding BreathingProgress}"
                                         ProgressColor="#3A8AC5"
                                         HeightRequest="4" />
                        </Border>

                        <Button Text="Parar"
                                BackgroundColor="#192736" TextColor="#8A9AAE"
                                CornerRadius="12" HeightRequest="40"
                                FontSize="13"
                                Command="{Binding StopBreathingCommand}" />
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>

            <!-- Coping phrases -->
            <Border Stroke="#1D2C3C" StrokeThickness="1"
                    BackgroundColor="#131D28"
                    Padding="16,14"
                    Margin="16,0,16,10"
                    StrokeShape="RoundRectangle 16,16,16,16">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Frases de Enfrentamento"
                           FontSize="15" FontAttributes="Bold"
                           TextColor="#E2E8F0" />
                    <Label Text="• Isso vai passar. Eu já passei por isso antes."
                           TextColor="#8A9AAE" FontSize="14" />
                    <Label Text="• Eu não preciso beber para lidar com isso."
                           TextColor="#8A9AAE" FontSize="14" />
                    <Label Text="• Um dia de cada vez. Só por hoje."
                           TextColor="#8A9AAE" FontSize="14" />
                    <Label Text="• Eu sou mais forte do que essa vontade."
                           TextColor="#8A9AAE" FontSize="14" />
                </VerticalStackLayout>
            </Border>

            <!-- HALT Check -->
            <Border Stroke="#1D2C3C" StrokeThickness="1"
                    BackgroundColor="#131D28"
                    Padding="16,14"
                    Margin="16,0,16,10"
                    StrokeShape="RoundRectangle 16,16,16,16">
                <VerticalStackLayout Spacing="12">
                    <Label Text="Check HALT"
                           FontSize="15" FontAttributes="Bold"
                           TextColor="#E2E8F0" />

                    <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto"
                          ColumnSpacing="10" RowSpacing="10">
                        <Border Grid.Row="0" Grid.Column="0"
                                StrokeThickness="1" Stroke="#1D2C3C"
                                BackgroundColor="#192736" Padding="12"
                                StrokeShape="RoundRectangle 12,12,12,12">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding OpenHaltCheckCommand}" />
                            </Border.GestureRecognizers>
                            <VerticalStackLayout HorizontalOptions="Center" Spacing="4">
                                <Label Text="&#x1F34E;" FontSize="24" HorizontalTextAlignment="Center" />
                                <Label Text="H" FontSize="18" FontAttributes="Bold"
                                       TextColor="#E2E8F0" HorizontalTextAlignment="Center" />
                            </VerticalStackLayout>
                        </Border>
                        <Border Grid.Row="0" Grid.Column="1"
                                StrokeThickness="1" Stroke="#1D2C3C"
                                BackgroundColor="#192736" Padding="12"
                                StrokeShape="RoundRectangle 12,12,12,12">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding OpenHaltCheckCommand}" />
                            </Border.GestureRecognizers>
                            <VerticalStackLayout HorizontalOptions="Center" Spacing="4">
                                <Label Text="&#x1F624;" FontSize="24" HorizontalTextAlignment="Center" />
                                <Label Text="A" FontSize="18" FontAttributes="Bold"
                                       TextColor="#E2E8F0" HorizontalTextAlignment="Center" />
                            </VerticalStackLayout>
                        </Border>
                        <Border Grid.Row="1" Grid.Column="0"
                                StrokeThickness="1" Stroke="#1D2C3C"
                                BackgroundColor="#192736" Padding="12"
                                StrokeShape="RoundRectangle 12,12,12,12">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding OpenHaltCheckCommand}" />
                            </Border.GestureRecognizers>
                            <VerticalStackLayout HorizontalOptions="Center" Spacing="4">
                                <Label Text="&#x1F614;" FontSize="24" HorizontalTextAlignment="Center" />
                                <Label Text="L" FontSize="18" FontAttributes="Bold"
                                       TextColor="#E2E8F0" HorizontalTextAlignment="Center" />
                            </VerticalStackLayout>
                        </Border>
                        <Border Grid.Row="1" Grid.Column="1"
                                StrokeThickness="1" Stroke="#1D2C3C"
                                BackgroundColor="#192736" Padding="12"
                                StrokeShape="RoundRectangle 12,12,12,12">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding OpenHaltCheckCommand}" />
                            </Border.GestureRecognizers>
                            <VerticalStackLayout HorizontalOptions="Center" Spacing="4">
                                <Label Text="&#x1F634;" FontSize="24" HorizontalTextAlignment="Center" />
                                <Label Text="T" FontSize="18" FontAttributes="Bold"
                                       TextColor="#E2E8F0" HorizontalTextAlignment="Center" />
                            </VerticalStackLayout>
                        </Border>
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <!-- Call CVV -->
            <Border Stroke="#C0392B" StrokeThickness="1"
                    BackgroundColor="#C0392B"
                    Padding="14"
                    Margin="16,0,16,0"
                    StrokeShape="RoundRectangle 14,14,14,14">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding CallCVVCommand}" />
                </Border.GestureRecognizers>
                <Label Text="&#x260E;&#xFE0F; Ligar CVV — 188"
                       TextColor="White" FontSize="16" FontAttributes="Bold"
                       HorizontalTextAlignment="Center" />
            </Border>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
