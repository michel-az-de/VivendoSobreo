<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:SoPorHoje.App.ViewModels"
             x:Class="SoPorHoje.App.Views.StepsPage"
             x:DataType="vm:StepsViewModel"
             BackgroundColor="#0C1219"
             Title="12 Passos">

    <ScrollView>
        <VerticalStackLayout Padding="0,8,0,24" Spacing="0">

            <Label Text="Os 12 Passos"
                   FontSize="22" FontAttributes="Bold"
                   TextColor="#E2E8F0"
                   Margin="16,8,16,12" />

            <CollectionView ItemsSource="{Binding Steps}">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="vm:StepItem">
                        <Border Stroke="#1D2C3C" StrokeThickness="1"
                                BackgroundColor="#131D28"
                                Padding="14"
                                Margin="16,0,16,8"
                                StrokeShape="RoundRectangle 16,16,16,16">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vm:StepsViewModel}}, Path=ToggleStepCommand}"
                                                      CommandParameter="{Binding .}" />
                            </Border.GestureRecognizers>
                            <VerticalStackLayout Spacing="8">
                                <HorizontalStackLayout Spacing="12">
                                    <Frame WidthRequest="32" HeightRequest="32"
                                           CornerRadius="16"
                                           BackgroundColor="#3A8AC5"
                                           Padding="0" HasShadow="False"
                                           VerticalOptions="Center">
                                        <Label Text="{Binding Number}"
                                               FontSize="14" FontAttributes="Bold"
                                               TextColor="White"
                                               HorizontalOptions="Center"
                                               VerticalOptions="Center" />
                                    </Frame>
                                    <Label Text="{Binding Title}"
                                           FontSize="15" FontAttributes="Bold"
                                           TextColor="#E2E8F0"
                                           VerticalOptions="Center" />
                                </HorizontalStackLayout>

                                <Label Text="{Binding Text}"
                                       FontAttributes="Italic"
                                       TextColor="#8A9AAE" FontSize="14"
                                       IsVisible="{Binding IsExpanded}"
                                       LineHeight="1.4"
                                       Margin="44,0,0,0" />
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
