<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:SoPorHoje.App.ViewModels"
             x:Class="SoPorHoje.App.Views.TraditionsPage"
             x:DataType="vm:TraditionsViewModel"
             BackgroundColor="{StaticResource BgPrimary}"
             Title="12 Tradições">

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="12">

            <Label Text="As 12 Tradições"
                   FontSize="24"
                   FontAttributes="Bold"
                   TextColor="{StaticResource TextPrimary}"
                   SemanticProperties.HeadingLevel="Level1" />

            <CollectionView ItemsSource="{Binding Traditions}">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="vm:TraditionItem">
                        <Border StrokeThickness="1"
                                Stroke="{StaticResource BgBorder}"
                                BackgroundColor="{StaticResource BgSurface}"
                                Padding="14,16"
                                Margin="0,4"
                                StrokeShape="RoundRectangle 16"
                                MinimumHeightRequest="44">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vm:TraditionsViewModel}}, Path=ToggleTraditionCommand}"
                                                      CommandParameter="{Binding .}" />
                            </Border.GestureRecognizers>
                            <VerticalStackLayout Spacing="8">
                                <HorizontalStackLayout Spacing="12">
                                    <!-- Number circle -->
                                    <Frame WidthRequest="36"
                                           HeightRequest="36"
                                           CornerRadius="18"
                                           BackgroundColor="{StaticResource Accent}"
                                           Padding="0"
                                           HasShadow="False"
                                           VerticalOptions="Center">
                                        <Label Text="{Binding Number}"
                                               FontSize="16"
                                               FontAttributes="Bold"
                                               TextColor="{StaticResource TextPrimary}"
                                               HorizontalOptions="Center"
                                               VerticalOptions="Center" />
                                    </Frame>
                                    <Label Text="{Binding Title}"
                                           FontSize="16"
                                           FontAttributes="Bold"
                                           TextColor="{StaticResource TextPrimary}"
                                           VerticalOptions="Center"
                                           HorizontalOptions="FillAndExpand" />
                                </HorizontalStackLayout>

                                <!-- Expanded text -->
                                <Label Text="{Binding Text}"
                                       FontAttributes="Italic"
                                       TextColor="{StaticResource TextSecondary}"
                                       FontSize="14"
                                       IsVisible="{Binding IsExpanded}"
                                       Margin="48,0,0,0" />
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <BoxView HeightRequest="16" Color="Transparent" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
